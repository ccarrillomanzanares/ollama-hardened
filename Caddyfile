{
	# Global block to configure security optimizations
	email ${EMAIL_ADMIN:-admin@localhost} # Required for Let's Encrypt notifications before expiration
	servers {
		metrics
	}
}

# Dynamic domain variable. If you set a real domain, Caddy manages the certificate automatically.
# If you leave it as "localhost", Caddy generates a self-signed local TLS certificate.
{$DOMAIN}:443 {
	# 1. Strict security headers (HSTS, X-Frame-Options)
	header {
		Strict-Transport-Security "max-age=31536000;"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
	}

	# Health endpoint for Docker (before authentication)
	handle /health {
		respond "OK" 200
	}

	# 2. Access control: If the API Key is incorrect, returns a JSON error and a 401 code.
	@noauth {
		not header X-API-Key "{$OLLAMA_API_KEY}"
	}
	respond @noauth `{"error": "Access denied. Invalid or missing API Key."}` 401

	# 3. Proxy to Ollama, but only if the API Key was correct
	reverse_proxy ollama:11434 {
		# Specific configurations to avoid timeouts on long responses (AI)
		transport http {
			response_header_timeout 5m # Large models may take time to load or generate responses
		}
	}
}
